{
  "id": "com.unwindcode.premiere.visualcortex",
  "name": "Unwind Visual Cortex",
  "version": "1.0.0",
  "main": "index.html",
  "host": [
    {
      "app": "PPRO",
      "minVersion": "25.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "unwind.panel",
      "label": {
        "default": "Visual Cortex"
      }
    }
  ],
  "requiredPermissions": [
    {
      "name": "network",
      "reason": "Required for communication with Unwind Visual Cortex server"
    },
    {
      "name": "localFileSystem",
      "reason": "Required for importing video assets"
    },
    {
      "name": "clipboard",
      "reason": "For copying project information"
    }
  ],
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/icon-24.png",
      "theme": [
        "dark",
        "light",
        "all"
      ]
    }
  ]
}
